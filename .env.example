# ─── LUMINARK OVERWATCH PRIME — Environment Variables ───────────────────────
# Copy to .env and fill in secrets before running.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://luminark:changeme@localhost:5432/luminark_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_REUSE_DETECTION=true

# ── Static API Keys (comma-separated, for machine clients / CI) ───────────────
# These skip DB lookup — keep short list or leave empty to use DB keys only
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ── Rate Limits (slowapi format: N/unit) ──────────────────────────────────────
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_ANALYZE=60/minute
RATE_LIMIT_TOKEN=10/minute

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Dashboard (optional — enables extended analysis panel) ────────────────────
# LUMINARK_API_URL=http://localhost:8000
# LUMINARK_DASHBOARD_TOKEN=<your_access_token>
